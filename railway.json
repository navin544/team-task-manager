{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "mongodb": {
      "image": "mongo:7",
      "config": {
        "env": {
          "MONGO_INITDB_DATABASE": "team_task_manager"
        }
      }
    },
    "backend": {
      "source": {
        "directory": "backend"
      },
      "config": {
        "healthcheck": "/health",
        "env": {
          "NODE_ENV": "production",
          "MONGODB_URI": "${{mongodb.RAILWAY_INTERNAL_URL}}",
          "MONGODB_DB_NAME": "team_task_manager"
        }
      },
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "npm run start"
      }
    },
    "frontend": {
      "source": {
        "directory": "frontend"
      },
      "config": {
        "env": {
          "VITE_API_URL": "${{backend.RAILWAY_PUBLIC_DOMAIN}}/api",
          "VITE_SOCKET_URL": "${{backend.RAILWAY_PUBLIC_DOMAIN}}"
        }
      },
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "npm run start"
      }
    }
  }
}
