NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/team_task_manager
MONGODB_DB_NAME=team_task_manager
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-strong-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=ttm_refresh
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Team Task Manager <no-reply@example.com>
RESET_PASSWORD_URL=http://localhost:5173/reset-password
UPLOAD_DIR=src/uploads
MAX_FILE_UPLOAD_SIZE=5242880
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
